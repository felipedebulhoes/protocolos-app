# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Database ---------------------------------------------------------------
# MySQL connection string used by drizzle-orm/mysql2.
DATABASE_URL="mysql://user:password@host:3306/protocolos_app"

# --- Sessions ----------------------------------------------------------------
# Signs both the doctor (Manus OAuth) and patient session cookies.
# REQUIRED in production — the server refuses to boot without it.
# Generate with: openssl rand -hex 32
JWT_SECRET="REPLACE_ME"

# --- Manus OAuth (doctor login) ---------------------------------------------
VITE_APP_ID=""
OAUTH_SERVER_URL="https://api.manus.im"
VITE_OAUTH_PORTAL_URL="https://manus.im"

# openId of the physician/owner account. Only this account can reach
# owner-only routes (patient data, exam files, dashboard, TOTP setup).
OWNER_OPEN_ID=""
OWNER_NAME=""

# --- Manus storage / Forge (file uploads, AI exam reading) -------------------
BUILT_IN_FORGE_API_URL="https://forge.manus.ai"
BUILT_IN_FORGE_API_KEY=""

# --- PII encryption ----------------------------------------------------------
# 32-byte key (hex-64 or base64) used to encrypt the patient CPF column at
# rest. Generate with: openssl rand -hex 32
# Required in production before any code path writes a patient CPF; in
# development, missing this just logs a warning and stores it in plaintext.
CPF_ENCRYPTION_KEY=""

# --- Misc ---------------------------------------------------------------------
PORT=3000
NODE_ENV=development
